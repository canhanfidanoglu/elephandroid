AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
SESSION_SECRET_KEY=change-this-to-a-random-secret-key

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./elephandroid.db
# Production: DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/elephandroid
# After changing DATABASE_URL, run: alembic upgrade head

# LLM Provider: "ollama" | "claude" | "openai" | "gemini" | "gemma"
LLM_PROVIDER=ollama

# Ollama (local SLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# Anthropic (if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini (if LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Gemma via Ollama (if LLM_PROVIDER=gemma)
# Uses Ollama backend with gemma3 model — no extra config needed,
# just make sure Ollama is running and gemma3 is pulled.

# Stripe (billing)
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Teams Bot (Azure Bot Service)
BOT_APP_ID=
BOT_APP_PASSWORD=

# Azure Communication Services (meeting bot)
ACS_CONNECTION_STRING=
ACS_CALLBACK_URL=http://localhost:8000/bot/callbacks

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=["*"]
# Production: CORS_ORIGINS=["https://yourdomain.com"]

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=120

# Logging
LOG_LEVEL=INFO
# Production: LOG_JSON=true for structured JSON logs
LOG_JSON=false
